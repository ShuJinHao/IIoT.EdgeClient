<!--  路径：src/Modules/IIoT.Edge.Module.Production/Monitor/MonitorView.xaml  -->
<UserControl
    x:Class="IIoT.Edge.Module.Production.Monitor.MonitorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="350"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="Margin" Value="0,8,0,2" />
        </Style>
        <Style x:Key="DataKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Margin" Value="12,1,4,1" />
        </Style>
        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#EEE" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Devices}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="4,4,4,8"
                        Padding="8"
                        Background="#1E1E1E"
                        CornerRadius="4">
                        <StackPanel>
                            <!--  设备名称  -->
                            <TextBlock
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="#4FC3F7"
                                Text="{Binding DeviceName}" />

                            <!--  状态机步骤  -->
                            <TextBlock Style="{StaticResource SectionHeader}" Text="── 状态机 ──" />
                            <ItemsControl ItemsSource="{Binding StepStates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource DataKey}" Text="{Binding Key}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="#666"
                                                Text=" = " />
                                            <TextBlock Style="{StaticResource DataValue}" Text="{Binding Value}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  设备级数据  -->
                            <TextBlock Style="{StaticResource SectionHeader}" Text="── 设备数据 ──" />
                            <ItemsControl ItemsSource="{Binding DeviceData}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource DataKey}" Text="{Binding Key}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="#666"
                                                Text=" = " />
                                            <TextBlock Style="{StaticResource DataValue}" Text="{Binding Value}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  在制电芯  -->
                            <TextBlock Style="{StaticResource SectionHeader}">
                                <Run Text="── 在制电芯 (" />
                                <Run Text="{Binding CellCount, Mode=OneWay}" />
                                <Run Text="个) ──" />
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Cells}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,2,0,6">
                                            <!--  条码标题  -->
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="#81C784"
                                                Text="{Binding Barcode}" />
                                            <!--  该电芯的所有参数  -->
                                            <ItemsControl ItemsSource="{Binding Data}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock
                                                                Margin="20,1,4,1"
                                                                Style="{StaticResource DataKey}"
                                                                Text="{Binding Key}" />
                                                            <TextBlock
                                                                FontSize="12"
                                                                Foreground="#666"
                                                                Text=" = " />
                                                            <TextBlock Style="{StaticResource DataValue}" Text="{Binding Value}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>