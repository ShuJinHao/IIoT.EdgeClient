<UserControl
    x:Class="IIoT.Edge.Module.Hardware.HardwareConfigView.HardwareConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:pages="clr-namespace:IIoT.Edge.Module.Hardware.HardwareConfigView.Pages"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="#E4E4E7"
                    Text="硬件配置" />
                <Button
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    Background="#0F766E"
                    BorderThickness="0"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="ContentSave" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="White"
                            Text="保存" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  主内容 TabControl  -->
        <TabControl
            Grid.Row="1"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="网口设备">
                <pages:NetworkDevicePage />
            </TabItem>
            <TabItem Header="串口设备">
                <pages:SerialDevicePage />
            </TabItem>
            <TabItem Header="IO映射">
                <pages:IoMappingPage />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>